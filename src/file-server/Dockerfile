ARG MY_CADDY_CFG_BASEIMAGE
FROM $MY_CADDY_CFG_BASEIMAGE

ARG MY_CORE_SET_DEBUG
ARG MY_CORE_SET_VERBOSE
ARG MY_CORE_PATH_INST64
ARG MY_CORE_PATH_SO64
ARG MY_CADDY_CFG_PORT

ENV \
    MY_CORE_PATH_SO64="${MY_CORE_PATH_SO64}" \
    MY_CADDY_CFG_PORT="${MY_CADDY_CFG_PORT}" \
    S64_CORE_SET_DEBUG="${MY_CORE_SET_DEBUG}" \
    S64_CORE_SET_VERBOSE="${MY_CORE_SET_VERBOSE}"

COPY --chmod=700 entrypoint.sh /entrypoint.sh

RUN \
    sudo -E "${MY_CORE_PATH_INST64}/install-caddy"

ENTRYPOINT ["/entrypoint.sh"]
