ARG GO64_DOCKER_CADDY_FILE__CFG_BASEIMAGE
FROM $GO64_DOCKER_CADDY_FILE__CFG_BASEIMAGE

ARG GO64_CORE__SET_DEBUG
ARG GO64_CORE__SET_VERBOSE
ARG GO64_CORE__PATH_INST64
ARG GO64_CORE__PATH_SO64
ARG GO64_DOCKER_CADDY_FILE__CFG_PORT

ENV \
    GO64_CORE__PATH_SO64="${GO64_CORE__PATH_SO64}" \
    GO64_DOCKER_CADDY_FILE__CFG_PORT="${GO64_DOCKER_CADDY_FILE__CFG_PORT}" \
    S64_CORE_SET_DEBUG="${GO64_CORE__SET_DEBUG}" \
    S64_CORE_SET_VERBOSE="${GO64_CORE__SET_VERBOSE}"

COPY --chmod=700 entrypoint.sh /entrypoint.sh

RUN \
    sudo -E "${GO64_CORE__PATH_INST64}/install-caddy"

ENTRYPOINT ["/entrypoint.sh"]
